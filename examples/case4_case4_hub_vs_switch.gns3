        "svg": "<svg width=\"693\" height=\"21\"><text x=\"2\" y=\"11\" font-family=\"sans-serif\" font-size=\"11\" font-weight=\"bold\" fill=\"#27ae60\">\u00d6wred\u00fd\u00e4r: Hub k\u00f6ne we ha\u00fdal, Kommutator akylly we \u00e7alt \u2014 h\u00e4zirki torlar kommutator ulan\u00fdar</text></svg>"
      },
